# Frontend Admin — Dev Environment
# Copy to .env.dev on VPS. NEVER commit real values.

# Domain for Traefik routing
ADMIN_HOST=dev.agendateya.app

# Dominio base del booking site (sin protocolo, sin slug)
# El admin construye: https://{slug}.{VITE_BOOKING_SITE_DOMAIN}
# Si no se define, usa el default de producción: site.agendateya.app
# Ejemplo staging: VITE_BOOKING_SITE_DOMAIN=staging.site.agendateya.app
VITE_BOOKING_SITE_DOMAIN=site.dev.agendateya.app
